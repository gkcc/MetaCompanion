<ItemsControl x:Class="MetaCompanion.PredictionLayout"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:controls="clr-namespace:Hearthstone_Deck_Tracker.Controls;assembly=HearthstoneDeckTracker"
		xmlns:tooltips="clr-namespace:Hearthstone_Deck_Tracker.Controls.Tooltips;assembly=HearthstoneDeckTracker"
		Height="Auto" Width="Auto" Background="Transparent">
	<Grid>
		<Border x:Name="RootBorder"
				Width="305"
				Background="#E61B222B"
				BorderBrush="#806D7C8C"
				BorderThickness="1"
				CornerRadius="4">
			<StackPanel>
				<Grid x:Name="HeaderBar" Height="38" Background="#F026303B" Cursor="SizeAll">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>
					<TextBlock x:Name="HeaderTitle"
							Grid.Column="0"
							Text="对手牌组预测"
							Foreground="#FFF4F7FA"
							FontSize="16"
							VerticalAlignment="Center"
							Margin="10,0,8,0"/>
					<TextBlock x:Name="StatusText"
							Grid.Column="1"
							Text="等待中"
							Foreground="#FFA4B8CC"
							FontSize="10"
							FontWeight="Bold"
							VerticalAlignment="Center"
							Margin="8,0,10,0"/>
				</Grid>
				<Border Background="#CC202933"
						BorderBrush="#405E6C7A"
						BorderThickness="0,1,0,1"
						Padding="10,6">
					<TextBlock x:Name="ArchetypeText"
							Text="尚未识别构筑"
							Foreground="#FFE7EDF2"
							FontSize="12"
							FontWeight="SemiBold"
							TextTrimming="CharacterEllipsis"
							ToolTip="{Binding RelativeSource={RelativeSource Self}, Path=Text}"/>
				</Border>

				<Border x:Name="EmptyState"
						MinHeight="76"
						Background="#99151B22"
						BorderBrush="#405E6C7A"
						BorderThickness="0,1,0,1">
					<TextBlock x:Name="EmptyStateText"
							Text="等待对手信息"
							Foreground="#FFB8C4D0"
							FontSize="13"
							TextAlignment="Center"
							TextWrapping="Wrap"
							HorizontalAlignment="Center"
							VerticalAlignment="Center"
							Margin="18,12"/>
				</Border>

				<Viewbox x:Name="CardView" Height="Auto" Visibility="Collapsed">
					<StackPanel Orientation="Horizontal">
						<controls:AnimatedCardList x:Name="CardList"
								Background="Transparent"
								BorderThickness="0"
								Width="221"
								IsEnabled="False"
								ScrollViewer.HorizontalScrollBarVisibility="Disabled"
								ScrollViewer.VerticalScrollBarVisibility="Disabled"
								ScrollViewer.CanContentScroll="False"/>
						<ItemsControl x:Name="PercentageList"
								Width="82"
								Grid.IsSharedSizeScope="True">
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<Border BorderBrush="#4D000000"
											BorderThickness="0,0,0,1"
											Background="#D92A3541"
											Visibility="{Binding ItemVisibility}">
										<Grid Height="{Binding CardHeight}" Opacity="{Binding ItemOpacity}">
											<Grid.ColumnDefinitions>
												<ColumnDefinition Width="*"/>
												<ColumnDefinition Width="24"/>
											</Grid.ColumnDefinitions>
											<TextBlock Grid.Column="0"
													Text="{Binding Percentage}"
													Foreground="#FFF3F6F8"
													FontSize="12"
													FontWeight="SemiBold"
													VerticalAlignment="Center"
													HorizontalAlignment="Right"
													Margin="4,0,5,0"/>
											<Image Grid.Column="1"
													Visibility="{Binding CoinVisibility}"
													Width="15" Height="15"
													HorizontalAlignment="Center"
													Source="Resources/icon_coin.png"/>
											<Image Grid.Column="1"
													Visibility="{Binding OptimalVisibility}"
													Width="15" Height="15"
													HorizontalAlignment="Center"
													Source="Resources/icon_optimal.png"/>
											<Image Grid.Column="1"
													Visibility="{Binding XVisibility}"
													Width="15" Height="15"
													HorizontalAlignment="Center"
													Source="Resources/icon_x.png"/>
										</Grid>
									</Border>
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</StackPanel>
				</Viewbox>

				<Grid x:Name="InfoBox" Height="43" Background="#F0212933">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="1"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<TextBlock x:Name="PossibleDecks"
							Grid.Column="0"
							Foreground="#FFD9E1E8"
							FontSize="11"
							TextAlignment="Center"
							TextWrapping="Wrap"
							VerticalAlignment="Center"
							Margin="6,0"/>
					<Border Grid.Column="1" Background="#506D7C8C" Margin="0,8"/>
					<TextBlock x:Name="PossibleCards"
							Grid.Column="2"
							Foreground="#FFD9E1E8"
							FontSize="11"
							TextAlignment="Center"
							TextWrapping="Wrap"
							VerticalAlignment="Center"
							Margin="6,0"/>
				</Grid>
			</StackPanel>
		</Border>

		<Canvas Panel.ZIndex="100">
			<tooltips:CardTooltip x:Name="CardToolTip"
					Height="Auto"
					VerticalAlignment="Top"
					Visibility="Hidden"/>
		</Canvas>
	</Grid>
</ItemsControl>

