<controls:MetroWindow x:Class="MetaCompanion.SettingsWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
		mc:Ignorable="d"
		BorderBrush="{DynamicResource AccentColorBrush}"
		BorderThickness="1"
		Title="Meta Companion 设置"
		Width="460"
		ResizeMode="NoResize"
		SizeToContent="Height">
	<Grid Margin="18">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Margin="0,0,0,14">
			<TextBlock Text="Meta Companion"
					FontSize="18"
					FontWeight="SemiBold"/>
			<TextBlock Text="标准环境流派推荐与对手形态识别"
					Foreground="#FF6E7B87"
					Margin="0,3,0,0"/>
		</StackPanel>

		<Border Grid.Row="1"
				BorderBrush="#405E6C7A"
				BorderThickness="0,1,0,1"
				Padding="0,12"
				Margin="0,0,0,12">
			<StackPanel>
				<CheckBox IsChecked="{Binding EnableMetaDashboard}"
						Content="启用卡组流派推荐"
						ToolTip="在传统对战入口显示推荐面板；进入实际对局后自动隐藏。"/>
				<CheckBox IsChecked="{Binding EnableLateGamePanel}"
						Content="启用剩余卡牌预测浮窗"
						Margin="0,8,0,0"
						ToolTip="仅在对手牌库剩余很少且已有足够真实证据时显示，避免遮挡 HDT 原生牌表。"/>
				<CheckBox IsChecked="{Binding EnableNativeHdtOpponentPredictions}"
						Content="启用 HDT 牌表内嵌预测"
						Margin="0,8,0,0"
						ToolTip="对局早中期把预测的前几张牌写入 HDT 对手牌表；不会修改 HDT 的全局显示设置。"/>
			</StackPanel>
		</Border>

		<StackPanel Grid.Row="2" Margin="0,0,0,14">
			<TextBlock Text="数据源" FontWeight="SemiBold"/>
			<TextBlock Text="{Binding DataStatus}"
					TextWrapping="Wrap"
					Foreground="#FF596773"
					Margin="0,4,0,0"/>
			<TextBlock Text="{Binding RecommendationStatus}"
					TextWrapping="Wrap"
					Foreground="#FF596773"
					Margin="0,3,0,0"/>
			<TextBlock Text="{Binding PremiumStatus}"
					TextWrapping="Wrap"
					Foreground="#FF596773"
					Margin="0,3,0,0"/>
		</StackPanel>

		<WrapPanel Grid.Row="3" HorizontalAlignment="Right">
			<Button Margin="0,0,8,0" Padding="12,5"
					Click="ButtonResetLayout_Click">重置浮窗位置</Button>
			<Button Padding="12,5"
					Click="ButtonOpenData_Click">打开数据目录</Button>
		</WrapPanel>
	</Grid>
</controls:MetroWindow>
